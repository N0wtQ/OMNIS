# ============================================================
#  MiroFish-ES — Variables de entorno
#  Copia este fichero a .env y rellena los valores
# ============================================================

# ----------------------------------------------------------
# LLM — Modelo de lenguaje
# Compatible con cualquier API en formato OpenAI.
#
# OPCIÓN GRATUITA: Groq (llama-3.3-70b-versatile)
#   → Regístrate en https://console.groq.com
#   → Crea una API key gratuita
# ----------------------------------------------------------
LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.3-70b-versatile

# Alternativa con Google Gemini (endpoint compatible con OpenAI):
#   LLM_API_KEY=AIza_xxx
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   LLM_MODEL_NAME=gemini-2.0-flash

# ----------------------------------------------------------
# ZEP CLOUD — Memoria persistente de agentes (OBLIGATORIO)
# Tier gratuito disponible en https://app.getzep.com
# Sin esta clave el backend de MiroFish no arranca.
# ----------------------------------------------------------
ZEP_API_KEY=z_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------
# LLM BOOST — modelo acelerador (OPCIONAL)
# Déjalo comentado si no lo usas.
# ----------------------------------------------------------
# LLM_BOOST_API_KEY=
# LLM_BOOST_BASE_URL=
# LLM_BOOST_MODEL_NAME=

# ----------------------------------------------------------
# FLASK
# ----------------------------------------------------------
FLASK_DEBUG=false
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-segura
